{
  "name": "controlcubiertas",
  "version": "2.1.1",
  "description": "Aplicación de escritorio para TireOps",
  "author": "Patricio Pittana",
  "main": "desktop/main.js",
  "scripts": {
    "build-react": "cd frontend && npm run build:electron",
    "build-desktop": "electron-builder",
    "build": "npm run build-react && npm run build-desktop",
    "electron:start": "electron .",
    "electron:build": "electron-builder",
    "electron": "electron ."
  },
  "devDependencies": {
    "concurrently": "^7.0.0",
    "electron": "^34.4.1",
    "electron-builder": "^24.4.0"
  },
  "build": {
    "appId": "com.tireops.app",
    "productName": "TireOps",
    "publish": {
      "provider": "github",
      "owner": "Lunatico0",
      "repo": "controlCubiertas"
    },
    "files": [
      "desktop/**/*",
      "node_modules/**/*",
      "package.json",
      "!../backend",
      "splash.html"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "desktop"
    },
    "asar": true,
    "win": {
      "icon": "desktop/icon.ico",
      "target": "nsis",
      "artifactName": "TireOps-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-log": "^5.4.1",
    "electron-updater": "^6.6.2"
  }
}
